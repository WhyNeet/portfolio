---
import '@fontsource-variable/geist-mono/wght.css';
import "../styles/global.css";
import Header from '../components/Header.astro';
import { ClientRouter } from "astro:transitions";
import { customTransition } from '../utils/transitions';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>whyneet</title>
		<ClientRouter />
	</head>
	<body class="bg-neutral-900 text-white" transition:animate="none">
		<Header />
		<main class="mx-auto max-w-5xl px-10 flex flex-col gap-10" transition:animate={customTransition}>
		  <slot />
		</main>
	</body>
</html>

<style is:global>
  /* Base optimization for smooth rendering */
  ::view-transition-old(root),
  ::view-transition-new(root) {
    will-change: transform, opacity, filter;
  }

  /* FORWARDS (Next Page) */
    @keyframes slide-out-up {
      0% { opacity: 1; transform: translateY(0); filter: blur(0); }
      100% { opacity: 0; transform: translateY(-40px); filter: blur(12px); }
    }
    @keyframes slide-in-up {
      0% {
        opacity: 0;
        transform: translateY(60px); /* Increased travel distance */
        filter: blur(15px); /* Heavier initial blur */
      }
      100% {
        opacity: 1;
        transform: translateY(0);
        filter: blur(0);
      }
    }

    /* BACKWARDS (Back Button) */
    @keyframes slide-out-down {
      0% { opacity: 1; transform: translateY(0); filter: blur(0); }
      100% { opacity: 0; transform: translateY(60px); filter: blur(15px); }
    }
    @keyframes slide-in-down {
      0% {
        opacity: 0;
        transform: translateY(-40px);
        filter: blur(12px);
      }
      100% {
        opacity: 1;
        transform: translateY(0);
        filter: blur(0);
      }
    }

    /* REFINED MORPHING ELEMENTS (Titles/Descriptions) */
    /* We want these to morph slightly faster than the page slides
       so they "land" right as the page finishes moving */
    ::view-transition-old(project-title-*),
    ::view-transition-new(project-title-*),
    ::view-transition-old(project-desc-*),
    ::view-transition-new(project-desc-*) {
      animation-duration: 500ms; /* Slightly faster than the root slide */
      animation-timing-function: cubic-bezier(0.32, 0.72, 0, 1);
    }
</style>

<script>
  document.addEventListener('astro:before-preparation', (event) => {
    // Check if the element that triggered the navigation has our data attribute
    const sourceElement = event.sourceElement as HTMLElement;

    if (sourceElement && sourceElement.hasAttribute('data-breadcrumb')) {
      // Force the animation to use the 'backwards' key from your customTransition
      event.direction = 'back';
    }
  });
</script>
