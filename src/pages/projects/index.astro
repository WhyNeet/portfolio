---
import { Icon } from "astro-icon/components";
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
---

<Layout>
  <div>
    <h1 class="font-bold text-lg">Projects</h1>
    <p class="text-white/50 text-sm">A selection of projects I've worked on. Some are open source, others are from professional environment.</p>
  </div>

  <ul>
    { projects.map(({ data: { name, description, timeline }, id }) => <li>
      <a href={`/projects/${id}`} class="group block -mx-3 rounded-lg p-3 hover:bg-white/5 relative">
        <h3 class="text-sm mb-1 flex gap-1 items-center">
          <span class="w-fit" data-vt-name={`project-title-${id}`}>
            { name }
          </span>
          <Icon name="material-symbols:arrow-outward" class:list="opacity-0 group-hover:opacity-50" />
        </h3>
        <p class="text-xs text-white/50 w-fit block origin-left"  data-vt-name={`project-desc-${id}`}>{ description }</p>
        <div class="text-white/50 text-xs absolute top-3 right-3">
          { timeline }
        </div>
      </a>
    </li>) }
  </ul>
</Layout>
